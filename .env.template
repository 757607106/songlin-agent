# YUXI_URL_WHITELIST=github.com,docs.example.com,gitlab.example.com,127.0.0.1

# # MinerU
# MINERU_API_KEY=
MINERU_API_URI=http://mineru-api:30001
MINERU_VL_SERVER=http://mineru-vllm-server:30000

# # RAG-Anything
RAG_ANYTHING_ENABLED=1
RAG_ANYTHING_QUERY_ENABLED=1
RAG_ANYTHING_VLM_ENABLED=0
# parser 可选 mineru/mineru_api/docling/paddleocr；默认使用 mineru_api（HTTP API 方式）
# 若 mineru_api 不可用，将自动回退到 docling/paddleocr
RAG_ANYTHING_PARSER=mineru_api
RAG_ANYTHING_PARSE_METHOD=auto
RAG_ANYTHING_ENABLE_IMAGE_PROCESSING=1
RAG_ANYTHING_ENABLE_TABLE_PROCESSING=1
RAG_ANYTHING_ENABLE_EQUATION_PROCESSING=1
RAG_ANYTHING_CONTEXT_WINDOW=1
RAG_ANYTHING_CONTEXT_MODE=page
RAG_ANYTHING_MAX_CONTEXT_TOKENS=2000
RAG_ANYTHING_TIMEOUT_SECONDS=120

LIGHTRAG_LLM_MAX_CONCURRENCY=1
LIGHTRAG_FORCE_LLM_MODEL=dashscope/qwen-turbo-latest
REPORTER_SCHEMA_MODEL=dashscope/qwen-turbo-latest
REPORTER_SQL_GEN_MODEL=dashscope/qwen-plus-latest
SCHEMA_SIMPLIFIED_MODE=true  # 是否简化数据库模式，默认开启
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_ENDPOINTS=/api/auth/token
LOGIN_RATE_LIMIT_USE_DB=1
LOGIN_RATE_LIMIT_LOCK_NAMESPACE=rate_limit
LOGIN_ADVISORY_LOCK_NAMESPACE=login
THREAD_DISTRIBUTED_LOCK_ENABLED=1
THREAD_DISTRIBUTED_LOCK_NAMESPACE=thread_stream

# Redis 配置 (任务队列持久化)
# REDIS_URL=redis://localhost:6379/0
TASK_QUEUE_USE_REDIS=1
